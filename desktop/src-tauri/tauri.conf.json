{
  "productName": "Agent OS Brain",
  "version": "0.2.0",
  "identifier": "com.agenteos.brain",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../frontend-dist",
    "devUrl": "http://localhost:43173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:* ws://localhost:* https://*.openai.com https://*.anthropic.com https://*.googleapis.com https://*.groq.com https://*.deepseek.com; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "resources": [
      "bin/backend-bundle.cjs",
      "bin/node",
      "bin/better_sqlite3.node",
      "bin/build/Release/better_sqlite3.node",
      "bin/migrations/*"
    ]
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "node",
          "cmd": "node",
          "args": true
        }
      ]
    }
  }
}
