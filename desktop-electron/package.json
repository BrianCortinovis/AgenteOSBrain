{
  "name": "agenteos-brain",
  "version": "0.2.0",
  "description": "Agent OS Brain — AI Agent Orchestration Platform",
  "main": "main.js",
  "author": "Brian Cortinovis",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "node build.js && electron-builder",
    "build:mac": "node build.js && electron-builder --mac",
    "build:dir": "node build.js && electron-builder --dir"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "better-sqlite3": "^11.6.0",
    "ws": "^8.18.0",
    "nanoid": "^3.3.7",
    "node-cron": "^3.0.3",
    "openai": "^4.73.0",
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.21.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.agenteos.brain",
    "productName": "Agent OS Brain",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ],
      "icon": "icons/icon.icns",
      "minimumSystemVersion": "11.0",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "Agent OS Brain",
      "iconSize": 100,
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "files": [
      "main.js",
      "backend-bundle.js",
      "frontend-dist/**/*",
      "migrations/**/*",
      "definitions/**/*",
      "icons/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend/src/database/migrations",
        "to": "migrations"
      },
      {
        "from": "default-data",
        "to": "default-data"
      }
    ],
    "asar": true
  }
}
