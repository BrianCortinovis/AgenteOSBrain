  {
    "id": "s3",
    "category": "cloud-storage",
    "name": "Amazon S3",
    "icon": "aws-s3",
    "description": "Archiviazione oggetti scalabile tramite Amazon S3",
    "status": "available",
    "configSchema": {
      "type": "object",
      "required": ["access_key_id", "secret_access_key"],
      "properties": {
        "access_key_id": {
          "type": "string",
          "title": "Access Key ID",
          "description": "Chiave di accesso AWS (inizia con AKIA)"
        },
        "secret_access_key": {
          "type": "string",
          "title": "Secret Access Key",
          "description": "Chiave segreta AWS associata all'Access Key ID",
          "format": "password"
        },
        "region": {
          "type": "string",
          "title": "Regione",
          "description": "Regione AWS (es. us-east-1, eu-west-1)",
          "default": "us-east-1"
        },
        "bucket": {
          "type": "string",
          "title": "Bucket",
          "description": "Nome del bucket S3 (opzionale)"
        }
      }
    },
    "actions": ["list_buckets", "list_objects", "upload_object", "download_object", "delete_object", "generate_presigned_url"]
  },
  {
