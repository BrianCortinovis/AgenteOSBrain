      "properties": {
        "cloud_name": {
          "type": "string",
          "title": "Cloud Name",
          "description": "Nome del tuo cloud Cloudinary"
        },
        "api_key": {
          "type": "string",
          "title": "API Key",
          "description": "Chiave API di Cloudinary"
        },
        "api_secret": {
          "type": "string",
          "title": "API Secret",
          "description": "Secret API di Cloudinary",
          "format": "password"
        }
      }
    },
    "actions": ["upload_media", "transform_image", "list_assets", "delete_asset", "generate_url"]
  },
  {
    "id": "local-folder",
    "category": "cloud-storage",
    "name": "Cartella Locale",
    "icon": "folder",
    "description": "Accedi a file e cartelle sul filesystem locale del server",
    "status": "available",
    "configSchema": {
      "type": "object",
      "required": ["base_path"],
      "properties": {
        "base_path": {
          "type": "string",
          "title": "Percorso base",
          "description": "Percorso assoluto della cartella locale da utilizzare"
        },
        "allowed_extensions": {
          "type": "array",
          "title": "Estensioni consentite",
          "description": "Lista di estensioni file consentite (es. .pdf, .txt). Vuoto per consentire tutto.",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "max_file_size_mb": {
          "type": "number",
          "title": "Dimensione massima file (MB)",
          "description": "Dimensione massima per singolo file in megabyte",
          "default": 100
        }
      }
    },
    "actions": ["list_files", "read_file", "write_file", "delete_file", "create_folder", "move_file", "copy_file"]
  },
  {
    "id": "nas-smb",
    "category": "cloud-storage",
    "name": "NAS / SMB",
    "icon": "nas",
    "description": "Connettiti a condivisioni di rete NAS tramite protocollo SMB/CIFS",
    "status": "available",
    "configSchema": {
      "type": "object",
      "required": ["host", "share"],
      "properties": {
        "host": {
          "type": "string",
          "title": "Host",
          "description": "Indirizzo IP o hostname del NAS"
        },
        "share": {
          "type": "string",
          "title": "Condivisione",
          "description": "Nome della condivisione SMB"
        },
        "username": {
          "type": "string",
          "title": "Utente",
          "description": "Nome utente per l'autenticazione (opzionale)"
        },
        "password": {
          "type": "string",
          "title": "Password",
          "description": "Password per l'autenticazione (opzionale)",
          "format": "password"
        },
        "domain": {
          "type": "string",
          "title": "Dominio",
          "description": "Dominio di rete (opzionale)"
        }
      }
    },
    "actions": ["list_files", "upload_file", "download_file", "create_folder", "delete_file"]
  },
  {
    "id": "ftp-sftp",
    "category": "cloud-storage",
    "name": "FTP / SFTP",
    "icon": "ftp",
    "description": "Trasferisci file tramite protocollo FTP o SFTP sicuro",
    "status": "available",
    "configSchema": {
      "type": "object",
      "required": ["host", "username", "password"],
      "properties": {
        "host": {
          "type": "string",
          "title": "Host",
          "description": "Indirizzo del server FTP/SFTP"
        },
        "port": {
          "type": "number",
          "title": "Porta",
          "description": "Porta del server",
          "default": 21
        },
        "username": {
          "type": "string",
          "title": "Utente",
          "description": "Nome utente per la connessione"
        },
        "password": {
          "type": "string",
          "title": "Password",
          "description": "Password per la connessione",
          "format": "password"
        },
        "protocol": {
          "type": "string",
          "title": "Protocollo",
          "description": "Protocollo di trasferimento file",
          "enum": ["ftp", "sftp"],
          "default": "sftp"
        }
      }
    },
    "actions": ["list_files", "upload_file", "download_file", "create_folder", "delete_file"]
  }
]
